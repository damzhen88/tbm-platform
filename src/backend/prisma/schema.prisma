// TBM - Complete Database Schema
// Thailand Business Matching Platform
// Version: 1.0 (From Figma Architecture)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  INVESTOR
  BUSINESS_OWNER
  BROKER
  ADMIN
}

enum VerificationLevel {
  UNVERIFIED
  EMAIL_VERIFIED
  ID_VERIFIED
  DOCS_CERTIFIED
}

enum ListingType {
  FUNDRAISING
  SALE
  COFOUNDER
  PARTNER
}

enum ListingStatus {
  DRAFT
  PENDING
  ACTIVE
  PAUSED
  CLOSED
  REJECTED
}

enum InquiryStatus {
  PENDING
  RESPONDED
  NDA_SENT
  NDA_SIGNED
  IN_PROGRESS
  CLOSED
}

enum DocumentCategory {
  KYC_ID_FRONT
  KYC_ID_BACK
  KYC_SELFIE
  COMPANY_CERT
  FINANCIAL_STATEMENT
  PITCH_DECK
  BUSINESS_PHOTO
  CONTRACT
  OTHER
}

enum NdaStatus {
  PENDING
  SIGNED
  EXPIRED
  REVOKED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  NEW_INQUIRY
  NDA_REQUEST
  NDA_SIGNED
  MESSAGE_RECEIVED
  VERIFICATION_UPDATE
  LISTING_APPROVED
  LISTING_REJECTED
  SYSTEM
}

// ============================================
// 1. USERS & AUTHENTICATION
// ============================================

model User {
  id                String             @id @default(cuid())
  supabaseAuthId    String             @unique
  email             String             @unique
  phone             String?            @unique
  lineUserId        String?            @unique
  role              UserRole           @default(BUSINESS_OWNER)
  verificationLevel VerificationLevel @default(UNVERIFIED)
  isActive          Boolean            @default(true)
  lastLoginAt       DateTime?
  lastLoginIp      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  profile           Profile?
  listings          Listing[]
  sentMessages     Message[]          @relation("sender")
  receivedMessages Message[]          @relation("receiver")
  documents         Document[]
  ndasSigned       NdaAgreement[]     @relation("signer")
  ndasReceived     NdaAgreement[]     @relation("listingOwner")
  verificationLogs VerificationLog[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  savedListings    SavedListing[]
  inquiries        Inquiry[]

  @@index([email])
  @@index([role])
  @@index([verificationLevel])
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal
  fullName        String
  fullNameTh      String?
  avatarUrl       String?
  bio            String?

  // Company
  companyName     String?
  companyNameTh   String?
  registrationNo String?
  website         String?
  industry        String[]
  businessSize   String?
  province       String?
  foundedYear    Int?

  // Investor-specific
  investmentRange  String?
  investmentStages String[]
  portfolio        String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyName])
  @@index([industry])
  @@index([province])
}

// ============================================
// 2. LISTINGS
// ============================================

model Listing {
  id              String         @id @default(cuid())
  ownerId         String
  owner           User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  type            ListingType
  status          ListingStatus  @default(DRAFT)

  // Business Info
  title           String
  titleTh         String?
  businessType    String
  description     String
  province        String
  foundedYear     Int?
  industry        String[]
  coverImageUrl   String?
  galleryUrls     String[]

  // Financials (range in explore, actual after NDA)
  targetAmount    Decimal?        @db.Decimal(15, 2)
  valuation       Decimal?        @db.Decimal(15, 2)
  annualRevenue   Decimal?        @db.Decimal(15, 2)
  ebitda         Decimal?        @db.Decimal(15, 2)
  grossMargin    Float?
  growthRate     Float?

  // Deal specific
  equityOffered   Float?
  askingPrice    Decimal?        @db.Decimal(15, 2)
  minParticipation Float?

  // Metadata
  viewCount       Int            @default(0)
  inquiryCount    Int            @default(0)
  isFeatured      Boolean        @default(false)
  requireNda      Boolean        @default(true)
  publishedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  documents       Document[]
  inquiries       Inquiry[]
  ndaAgreements   NdaAgreement[]
  savedBy         SavedListing[]
  teamMembers     TeamMember[]

  @@index([ownerId])
  @@index([type])
  @@index([status])
  @@index([industry])
  @@index([province])
  @@index([status, type, publishedAt])
}

model TeamMember {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  name        String
  role        String
  experience  String?
  avatarUrl   String?
  order       Int      @default(0)
}

model SavedListing {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([userId, listingId])
}

// ============================================
// 3. MESSAGING
// ============================================

model Conversation {
  id              String    @id @default(cuid())
  participants    String[]
  listingId       String?
  lastMessage     String?
  lastMessageAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  messages       Message[]

  @@index([participants])
}

model Message {
  id              String       @id @default(cuid())
  conversationId   String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User         @relation("sender", fields: [senderId], references: [id])
  receiverId      String
  receiver        User         @relation("receiver", fields: [receiverId], references: [id])
  content         String
  attachmentUrl  String?
  attachmentType String?
  isRead          Boolean      @default(false)
  readAt          DateTime?
  createdAt       DateTime    @default(now())

  @@index([conversationId, createdAt])
  @@index([receiverId, isRead])
}

// ============================================
// 4. INQUIRIES
// ============================================

model Inquiry {
  id          String         @id @default(cuid())
  listingId   String
  listing     Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  status      InquiryStatus @default(PENDING)
  message     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([listingId, userId])
  @@index([listingId, status])
}

// ============================================
// 5. DOCUMENTS & DATA ROOM
// ============================================

model Document {
  id              String          @id @default(cuid())
  uploaderId      String
  uploader        User            @relation(fields: [uploaderId], references: [id])
  listingId       String?
  listing         Listing?        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  category        DocumentCategory
  fileName        String
  fileSize        Int
  mimeType        String
  storagePath     String
  isConfidential  Boolean         @default(true)
  isVerified      Boolean         @default(false)
  createdAt       DateTime        @default(now())

  accessLogs     DocumentAccessLog[]

  @@index([listingId, category])
  @@index([uploaderId])
}

model DocumentAccessLog {
  id           String   @id @default(cuid())
  documentId   String
  document     Document @relation(fields: [documentId], references: [id])
  userId       String
  action       String
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([documentId, createdAt])
}

// ============================================
// 6. NDA AGREEMENTS
// ============================================

model NdaAgreement {
  id              String     @id @default(cuid())
  listingId       String
  listing         Listing    @relation(fields: [listingId], references: [id], onDelete: Cascade)
  signerId        String
  signer          User       @relation("signer", fields: [signerId], references: [id])
  listingOwnerId String
  listingOwner   User       @relation("listingOwner", fields: [listingOwnerId], references: [id])
  status         NdaStatus  @default(PENDING)
  signedName     String?
  signedAt       DateTime?
  expiresAt      DateTime?
  signerIp       String?
  createdAt      DateTime   @default(now())

  @@unique([listingId, signerId])
  @@index([listingId, status])
}

// ============================================
// 7. VERIFICATION SYSTEM
// ============================================

model VerificationLog {
  id            String             @id @default(cuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id])
  level         VerificationLevel
  status        VerificationStatus @default(PENDING)
  documentIds   String[]
  reviewedBy    String?
  reviewNote    String?
  reviewedAt    DateTime?
  createdAt     DateTime           @default(now())

  @@index([userId, level])
  @@index([status])
}

// ============================================
// 8. NOTIFICATIONS
// ============================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  linkUrl   String?
  isRead    Boolean          @default(false)
  createdAt DateTime        @default(now())

  @@index([userId, isRead, createdAt])
}

// ============================================
// 9. AUDIT LOG
// ============================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  resource   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId, action])
  @@index([createdAt])
}
